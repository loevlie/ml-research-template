def test_binary_extra_watch_diff_marker(pkg, tmp_path):
    (Path.cwd() / "data.bin").write_bytes(b"\x00\x01\xff")
    codever.stamp(make_infra(tmp_path), packages=["watched"], extra_watch=["data.bin"])
    (Path.cwd() / "data.bin").write_bytes(b"\x00\x02\xfe")
    codever.stamp(make_infra(tmp_path), packages=["watched"], extra_watch=["data.bin"])
    log = (tmp_path / "cache" / "code_versions" / "CHANGELOG.md").read_text()
    assert "Binary file extra/data.bin changed" in log


def test_extra_watch_escape_rejected(pkg, tmp_path):
    outside = tmp_path.parent / f"outside-{tmp_path.name}.txt"
    outside.write_text("x")
    (Path.cwd() / "link.txt").symlink_to(outside)
    with pytest.raises(ValueError, match="escapes cwd"):
        codever.fingerprint(packages=["watched"], extra_watch=["link.txt"])


