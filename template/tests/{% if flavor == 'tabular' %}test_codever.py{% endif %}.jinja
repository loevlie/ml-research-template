# ---- review regressions: stale-hit class ----


def test_symlinked_dir_is_fingerprinted(pkg, tmp_path):
    shared = tmp_path / "shared_lib"
    shared.mkdir()
    (shared / "engine.py").write_text("def factor():\n    return 10\n")
    (pkg / "sub").symlink_to(shared)

    fp1, manifest = codever.fingerprint(packages=["watched"])
    assert "watched/sub/engine.py" in manifest
    (shared / "engine.py").write_text("def factor():\n    return 1000\n")
    assert codever.fingerprint(packages=["watched"])[0] != fp1


def test_symlink_cycle_terminates(pkg):
    (pkg / "loop").symlink_to(pkg)  # package contains a symlink to itself
    _fp, manifest = codever.fingerprint(packages=["watched"])  # must not hang
    assert "watched/core.py" in manifest


def test_namespace_package_all_locations(tmp_path, monkeypatch):
    for site, mod in [("site1", "a"), ("site2", "b")]:
        d = tmp_path / site / "nsp"
        d.mkdir(parents=True)
        (d / f"{mod}.py").write_text(f"{mod.upper()} = 1\n")
    monkeypatch.syspath_prepend(str(tmp_path / "site1"))
    monkeypatch.syspath_prepend(str(tmp_path / "site2"))
    monkeypatch.chdir(tmp_path)

    fp1, manifest = codever.fingerprint(packages=["nsp"])
    assert {"nsp/a.py", "nsp/b.py"} <= set(manifest)
    (tmp_path / "site1" / "nsp" / "a.py").write_text("A = 999\n")
    assert codever.fingerprint(packages=["nsp"])[0] != fp1


def test_restamp_same_object_after_edit_raises(pkg, tmp_path):
    infra = make_infra(tmp_path)
    v = codever.stamp(infra, packages=["watched"])
    assert codever.stamp(infra, packages=["watched"]) == v  # unchanged: quiet no-op
    (pkg / "core.py").write_text(BASE_SRC.replace("SCALE = 10", "SCALE = 77"))
    with pytest.raises(RuntimeError, match="fresh config"):
        codever.stamp(infra, packages=["watched"])


def test_verify_guards_edit_after_submit(pkg, tmp_path):
    infra = make_infra(tmp_path)
    codever.stamp(infra, packages=["watched"])
    codever.verify(infra, packages=["watched"])  # unchanged: passes
    (pkg / "core.py").write_text(BASE_SRC.replace("SCALE = 10", "SCALE = 555"))
    with pytest.raises(RuntimeError, match="code changed while the job was queued"):
        codever.verify(infra, packages=["watched"])


