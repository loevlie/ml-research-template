def test_codever_off_env(pkg, tmp_path, monkeypatch):
    monkeypatch.setenv("CODEVER_OFF", "1")
    infra = make_infra(tmp_path)
    assert codever.stamp(infra, packages=["watched"]) == "0"
    assert infra.version == "0"


