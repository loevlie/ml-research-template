"""Smoke tests for the model and data pipeline (JAX).

Can the model overfit a single batch?
These tests verify the basic pipeline works end-to-end.
"""

import jax
import jax.numpy as jnp
import optax
from flax import nnx

from {{ package_name }}.configs import DataConfig, ModelConfig
from {{ package_name }}.data.datamodule import create_dataloaders
from {{ package_name }}.models.module import ExampleModel, build_model
from {{ package_name }}.utils.seed import set_seed


def test_forward_pass():
    """Model produces correct output shape."""
    model = ExampleModel(n_features=32, hidden_dim=64, n_classes=10, rngs=nnx.Rngs(42))
    x = jax.random.normal(jax.random.key(0), (8, 32))
    out = model(x)
    assert out.shape == (8, 10)


def test_overfit_single_batch():
    """Model can memorize a single batch."""
    model = ExampleModel(n_features=32, hidden_dim=128, n_classes=10, rngs=nnx.Rngs(42))
    optimizer = nnx.Optimizer(model, optax.adamw(1e-2), wrt=nnx.Param)
    x = jax.random.normal(jax.random.key(0), (8, 32))
    y = jax.random.randint(jax.random.key(1), (8,), 0, 10)

    @nnx.jit
    def step(model, optimizer):
        def loss_fn(model):
            logits = model(x)
            return optax.softmax_cross_entropy_with_integer_labels(logits, y).mean()

        loss, grads = nnx.value_and_grad(loss_fn)(model)
        optimizer.update(model, grads)
        return loss

    model.train()
    for _ in range(200):
        loss = step(model, optimizer)

    assert float(loss) < 0.01, f"Model failed to overfit single batch: loss={float(loss):.4f}"


def test_dataloaders():
    """Dataloaders create train and val splits."""
    set_seed(42)
    cfg = DataConfig(n_samples=100, batch_size=16)
    loaders = create_dataloaders(cfg, seed=42)
    assert len(loaders.train) > 0
    assert len(loaders.val) > 0


def test_build_model_seam():
    """build_model produces a model matching the (resolved) config."""
    cfg = ModelConfig(hidden_dim=64, n_features=32, n_classes=10)
    model = build_model(cfg, seed=42)
    out = model(jnp.ones((8, 32)))
    assert out.shape == (8, 10)


def test_loss_at_init():
    """Loss at initialization matches -log(1/n_classes)."""
    n_classes = 10
    model = ExampleModel(n_features=32, hidden_dim=64, n_classes=n_classes, rngs=nnx.Rngs(42))
    model.eval()

    x = jax.random.normal(jax.random.key(0), (64, 32))
    y = jax.random.randint(jax.random.key(1), (64,), 0, n_classes)
    logits = model(x)
    loss = optax.softmax_cross_entropy_with_integer_labels(logits, y).mean()

    expected = -jnp.log(1.0 / n_classes)
    assert abs(float(loss) - float(expected)) < 0.5, (
        f"Init loss {float(loss):.3f} far from expected {float(expected):.3f}"
    )
