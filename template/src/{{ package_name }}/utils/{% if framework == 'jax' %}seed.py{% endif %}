"""Reproducibility utilities (JAX).

JAX needs less machinery here than torch: model init takes an explicit key
(nnx.Rngs(seed) in models/module.py), the data pipeline seeds its own numpy
generators (data/datamodule.py), and XLA ops are deterministic by default on
CPU. This module covers what's left — stdlib/numpy seeding and best-effort
GPU determinism.
"""

import os
import random

import numpy as np


def set_seed(seed: int = 42, *, deterministic: bool = True) -> None:
    """Seed Python and NumPy RNGs; optionally request deterministic GPU ops.

    Args:
        seed: Integer seed value.
        deterministic: If True, sets XLA_FLAGS for deterministic GPU ops.
            Takes effect only if set before JAX initializes its backend —
            i.e. before the first jax operation. For SLURM jobs, exporting
            XLA_FLAGS in the sbatch script is the reliable route.
    """
    random.seed(seed)
    np.random.seed(seed)
    os.environ["PYTHONHASHSEED"] = str(seed)

    if deterministic:
        flags = os.environ.get("XLA_FLAGS", "")
        if "--xla_gpu_deterministic_ops" not in flags:
            os.environ["XLA_FLAGS"] = f"{flags} --xla_gpu_deterministic_ops=true".strip()
