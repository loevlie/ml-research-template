"""One benchmark cell: fit one estimator on one OpenML (task, fold), save metrics.

Tabular-FM evaluation is many small jobs, not one big training run. This entry
point is the unit of work; the grid lives in scripts/run_benchmark.sh (local)
and scripts/sbatch_benchmark.sh (SLURM array). Aggregate with
scripts/aggregate_benchmark.py.

Cells are cached on disk by exca, keyed on (estimator config, task, fold,
seed, code version): re-running a grid recomputes only missing cells, and
utils/codever.py busts the cache automatically when package code changes
(see cache/benchmark/code_versions/CHANGELOG.md for what changed when).

Estimators are typed configs — add one by defining a config class with a
build() and registering it in ESTIMATORS below.

Usage:
    python src/{{ package_name }}/benchmark.py                                 # logreg on credit-g
    python src/{{ package_name }}/benchmark.py estimator=tabpfn task_id=3913 fold=2
    python src/{{ package_name }}/benchmark.py estimator=mlp estimator.hidden_dim=64
"""

import json
import time
from typing import Literal

import exca
import numpy as np
import pydantic
from sklearn.metrics import accuracy_score, balanced_accuracy_score, log_loss, roc_auc_score

from {{ package_name }}.data.openml_data import load_openml_task
from {{ package_name }}.utils import cli, codever
from {{ package_name }}.utils.run_dir import create_run_dir
from {{ package_name }}.utils.seed import set_seed

# --- estimators (swap via `estimator=<name>`; add yours here) ------------------


class EstimatorConfigBase(pydantic.BaseModel):
    """An estimator config builds an sklearn-style estimator."""

    def build(self):
        raise NotImplementedError


class LogregConfig(EstimatorConfigBase):
    """Sanity-check baseline: if a foundation model doesn't beat this, stop."""

    kind: Literal["logreg"] = "logreg"
    max_iter: int = 1000

    def build(self):
        from sklearn.linear_model import LogisticRegression

        return LogisticRegression(max_iter=self.max_iter)


class TorchMLPConfig(EstimatorConfigBase):
    """Your torch model behind the sklearn interface (see sklearn_wrapper.py)."""

    kind: Literal["mlp"] = "mlp"
    hidden_dim: int = 128
    lr: float = 1e-3
    max_epochs: int = 50
    random_state: int | None = None  # derived from seed unless set

    def build(self):
        from {{ package_name }}.sklearn_wrapper import TorchMLPClassifier

        return TorchMLPClassifier(
            hidden_dim=self.hidden_dim,
            lr=self.lr,
            max_epochs=self.max_epochs,
            random_state=self.random_state or 0,
        )


class TabPFNConfig(EstimatorConfigBase):
    """TabPFN baseline. Needs: uv sync --extra tabular-baselines.

    NOTE: TabPFN weights are licensed for non-commercial research use.
    """

    kind: Literal["tabpfn"] = "tabpfn"

    def build(self):
        from tabpfn import TabPFNClassifier

        return TabPFNClassifier()


class TabICLConfig(EstimatorConfigBase):
    """TabICL baseline (fully open). Needs: uv sync --extra tabular-baselines."""

    kind: Literal["tabicl"] = "tabicl"

    def build(self):
        from tabicl import TabICLClassifier

        return TabICLClassifier()


ESTIMATORS: dict[str, type[EstimatorConfigBase]] = {
    "logreg": LogregConfig,
    "mlp": TorchMLPConfig,
    "tabpfn": TabPFNConfig,
    "tabicl": TabICLConfig,
}

EstimatorUnion = LogregConfig | TorchMLPConfig | TabPFNConfig | TabICLConfig


# --- config ---------------------------------------------------------------------


class CacheConfig(pydantic.BaseModel):
    enabled: bool = True
    folder: str = "cache/benchmark"


class BenchmarkConfig(pydantic.BaseModel):
    seed: int = 42
    task_id: int = 31  # OpenML task (31 = credit-g: small, fast). Browse: openml.org
    fold: int = 0  # OpenML tasks ship standardized 10-fold CV splits
    run_dir: str | None = None
    estimator: EstimatorUnion = pydantic.Field(default_factory=LogregConfig, discriminator="kind")
    cache: CacheConfig = CacheConfig()

    def resolved(self) -> "BenchmarkConfig":
        cfg = self.model_copy(deep=True)
        if isinstance(cfg.estimator, TorchMLPConfig) and cfg.estimator.random_state is None:
            cfg.estimator.random_state = cfg.seed
        return cfg


# --- the cell -------------------------------------------------------------------


def _evaluate(estimator_spec: dict, task_id: int, fold: int, seed: int) -> dict:
    """Compute one (estimator, task, fold) cell — pure function of its arguments."""
    set_seed(seed, deterministic=False)
    split = load_openml_task(task_id, fold=fold)
    estimator = ESTIMATORS[estimator_spec["kind"]](**estimator_spec).build()

    t0 = time.perf_counter()
    estimator.fit(split.X_train, split.y_train)
    fit_seconds = time.perf_counter() - t0

    t0 = time.perf_counter()
    y_pred = estimator.predict(split.X_test)
    predict_seconds = time.perf_counter() - t0

    metrics: dict = {
        "task_id": split.task_id,
        "dataset": split.dataset_name,
        "fold": split.fold,
        "seed": seed,
        "n_train": len(split.y_train),
        "n_test": len(split.y_test),
        "n_classes": split.n_classes,
        "acc": float(accuracy_score(split.y_test, y_pred)),
        "balanced_acc": float(balanced_accuracy_score(split.y_test, y_pred)),
        "fit_seconds": fit_seconds,
        "predict_seconds": predict_seconds,
    }

    if hasattr(estimator, "predict_proba"):
        proba = np.asarray(estimator.predict_proba(split.X_test))
        labels = list(range(split.n_classes))
        metrics["log_loss"] = float(log_loss(split.y_test, proba, labels=labels))
        try:
            if split.n_classes == 2:
                metrics["roc_auc"] = float(roc_auc_score(split.y_test, proba[:, 1]))
            else:
                metrics["roc_auc"] = float(
                    roc_auc_score(split.y_test, proba, multi_class="ovr", labels=labels)
                )
        except ValueError:
            pass  # e.g. a class missing from this test fold

    return metrics


class BenchmarkCell(pydantic.BaseModel):
    """The exca-cached unit of work.

    The estimator goes in as its full dump (defaults included, with the
    `kind` discriminator) so the cache uid is unambiguous across estimator
    types — two different estimators can never share a uid.
    """

    estimator: dict
    task_id: int
    fold: int
    seed: int
    infra: exca.TaskInfra = exca.TaskInfra()

    @infra.apply
    def compute(self) -> dict:
        return _evaluate(self.estimator, self.task_id, self.fold, self.seed)


def main() -> float:
    """Run one (estimator, task, fold) cell and write metrics.json.

    Returns:
        Test accuracy.
    """
    cfg = cli.parse(
        BenchmarkConfig,
        groups={"estimator": ESTIMATORS},
        description="One benchmark cell. Grid scripts: run_benchmark.sh / sbatch_benchmark.sh.",
    ).resolved()
    output_dir = create_run_dir(cfg, cfg.run_dir, root="outputs/benchmark")

    estimator_spec = cfg.estimator.model_dump(mode="json")  # includes the kind discriminator

    if cfg.cache.enabled:
        cell = BenchmarkCell(
            estimator=estimator_spec,
            task_id=cfg.task_id,
            fold=cfg.fold,
            seed=cfg.seed,
            infra=exca.TaskInfra(folder=cfg.cache.folder),
        )
        codever.stamp(cell.infra, packages=["{{ package_name }}"])
        metrics = cell.compute()
    else:
        metrics = _evaluate(estimator_spec, cfg.task_id, cfg.fold, cfg.seed)

    with open(output_dir / "metrics.json", "w") as f:
        json.dump(metrics, f, indent=2)

    print(
        f"{metrics['dataset']} (task {metrics['task_id']}, fold {metrics['fold']}): "
        f"acc={metrics['acc']:.4f} balanced_acc={metrics['balanced_acc']:.4f} "
        f"fit={metrics['fit_seconds']:.1f}s"
    )
    return float(metrics["acc"])


if __name__ == "__main__":
    main()
