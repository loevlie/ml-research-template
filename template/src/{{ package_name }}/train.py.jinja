"""Training entry point.

The training loop is explicit -- no hidden hooks or callbacks.
Fabric handles device placement, distributed, and mixed precision.

Usage:
    python src/{{ package_name }}/train.py                           # defaults
    python src/{{ package_name }}/train.py experiment=example         # named experiment
    python src/{{ package_name }}/train.py model.lr=1e-3 seed=123    # CLI overrides
"""

import json
from pathlib import Path

import hydra
import lightning as L
import torch
import torch.nn as nn
from omegaconf import DictConfig, OmegaConf
from torch.utils.data import DataLoader

from {{ package_name }}.data.datamodule import create_dataloaders
from {{ package_name }}.models.module import ExampleModel
from {{ package_name }}.utils.seed import set_seed


def train_epoch(
    fabric: L.Fabric,
    model: nn.Module,
    optimizer: torch.optim.Optimizer,
    train_loader: torch.utils.data.DataLoader,
    epoch: int,
) -> float:
    """Run one training epoch.

    Args:
        fabric: Lightning Fabric instance (for logging).
        model: The model to train.
        optimizer: The optimizer.
        train_loader: Training dataloader (already wrapped by Fabric).
        epoch: Current epoch number.

    Returns:
        Average training loss for the epoch.
    """
    model.train()
    total_loss = 0.0
    n_batches = 0

    for batch_idx, (x, y) in enumerate(train_loader):
        optimizer.zero_grad()
        logits = model(x)
        loss = nn.functional.cross_entropy(logits, y)
        fabric.backward(loss)
        fabric.clip_gradients(model, optimizer, max_norm=1.0)
        optimizer.step()

        total_loss += loss.item()
        n_batches += 1

        if batch_idx % 10 == 0:
            fabric.log("train/loss_step", loss.item(), step=epoch * len(train_loader) + batch_idx)

    avg_loss = total_loss / n_batches
    fabric.log("train/loss_epoch", avg_loss, step=epoch)
    return avg_loss


@torch.no_grad()
def validate(
    fabric: L.Fabric,
    model: nn.Module,
    val_loader: torch.utils.data.DataLoader,
    epoch: int,
) -> tuple[float, float]:
    """Run validation.

    Args:
        fabric: Lightning Fabric instance (for logging).
        model: The model to evaluate.
        val_loader: Validation dataloader (already wrapped by Fabric).
        epoch: Current epoch number.

    Returns:
        Tuple of (average val loss, accuracy).
    """
    model.eval()
    total_loss = 0.0
    correct = 0
    total = 0

    for x, y in val_loader:
        logits = model(x)
        loss = nn.functional.cross_entropy(logits, y)
        total_loss += loss.item()
        correct += (logits.argmax(dim=1) == y).sum().item()
        total += y.size(0)

    avg_loss = total_loss / len(val_loader)
    accuracy = correct / total

    fabric.log("val/loss", avg_loss, step=epoch)
    fabric.log("val/acc", accuracy, step=epoch)
    return avg_loss, accuracy


@hydra.main(version_base="1.3", config_path="../../configs", config_name="train")
def main(cfg: DictConfig) -> float | None:
    """Train a model.

    Args:
        cfg: Hydra config composed from configs/train.yaml + overrides.

    Returns:
        Best validation metric (for HP search), or None.
    """
    set_seed(cfg.seed, deterministic=cfg.get("deterministic", True))

    # --- Fabric ---
    loggers = []
    if "logger" in cfg:
        for _, lg_cfg in cfg.logger.items():
            loggers.append(hydra.utils.instantiate(lg_cfg))

    fabric = L.Fabric(
        accelerator=cfg.trainer.accelerator,
        devices=cfg.trainer.devices,
        precision=cfg.trainer.precision,
        loggers=loggers or None,
    )
    fabric.launch()

    # --- Data ---
    loaders = create_dataloaders(
        n_samples=cfg.data.n_samples,
        n_features=cfg.data.n_features,
        n_classes=cfg.data.n_classes,
        batch_size=cfg.data.batch_size,
        num_workers=cfg.data.num_workers,
        val_split=cfg.data.val_split,
        seed=cfg.seed,
    )

    # --- Model + Optimizer ---
    model = ExampleModel(
        n_features=cfg.model.n_features,
        hidden_dim=cfg.model.hidden_dim,
        n_classes=cfg.model.n_classes,
    )
    optimizer = torch.optim.Adam(
        model.parameters(), lr=cfg.model.lr, weight_decay=cfg.model.weight_decay
    )

    # Fabric wraps model, optimizer, dataloaders
    model, optimizer = fabric.setup(model, optimizer)
    train_loader: DataLoader = fabric.setup_dataloaders(loaders.train)  # type: ignore[assignment]
    val_loader: DataLoader = fabric.setup_dataloaders(loaders.val)  # type: ignore[assignment]

    # --- Training loop ---
    best_val_loss = float("inf")
    best_val_acc = 0.0
    patience_counter = 0
    output_dir = Path(hydra.core.hydra_config.HydraConfig.get().runtime.output_dir)  # type: ignore[attr-defined]

    fabric.print(f"Config:\n{OmegaConf.to_yaml(cfg)}")
    fabric.print(f"Output dir: {output_dir}")
    fabric.print(f"Parameters: {sum(p.numel() for p in model.parameters()):,}")

    for epoch in range(cfg.trainer.max_epochs):
        train_loss = train_epoch(fabric, model, optimizer, train_loader, epoch)
        val_loss, val_acc = validate(fabric, model, val_loader, epoch)

        fabric.print(
            f"Epoch {epoch:3d} | train_loss={train_loss:.4f} | "
            f"val_loss={val_loss:.4f} | val_acc={val_acc:.4f}"
        )

        # Checkpointing
        if val_loss < best_val_loss:
            best_val_loss = val_loss
            best_val_acc = val_acc
            patience_counter = 0
            state = {"model": model, "optimizer": optimizer, "epoch": epoch}
            fabric.save(output_dir / "best.ckpt", state)
        else:
            patience_counter += 1

        # Early stopping
        if patience_counter >= cfg.trainer.patience:
            fabric.print(f"Early stopping at epoch {epoch} (patience={cfg.trainer.patience})")
            break

    # Save final metrics for multi-seed aggregation
    metrics = {"val/loss": best_val_loss, "val/acc": best_val_acc}
    with open(output_dir / "metrics.json", "w") as f:
        json.dump(metrics, f, indent=2)

    fabric.print(f"Best val_loss={best_val_loss:.4f} | val_acc={best_val_acc:.4f}")
    return best_val_acc


if __name__ == "__main__":
    main()
