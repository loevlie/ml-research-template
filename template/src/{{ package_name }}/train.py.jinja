"""Training entry point.

Thin orchestrator: instantiate config → build data/model/objective/optim →
call training loop primitives. The loop itself lives in `training_loop.py`,
and the loss + forward pass live in `objectives.py` — swap them without
touching this file.

Usage:
    python src/{{ package_name }}/train.py                           # defaults
    python src/{{ package_name }}/train.py experiment=example         # named experiment
    python src/{{ package_name }}/train.py loss=contrastive           # swap objective
    python src/{{ package_name }}/train.py model.lr=1e-3 seed=123    # CLI overrides
"""

import json
import math
from pathlib import Path

import hydra
import lightning as L
import torch
from omegaconf import DictConfig, OmegaConf
from torch.utils.data import DataLoader

from {{ package_name }}.data.datamodule import create_dataloaders
from {{ package_name }}.models.module import ExampleModel
from {{ package_name }}.training_loop import train_epoch, validate
from {{ package_name }}.utils.schedulers import build_scheduler
from {{ package_name }}.utils.seed import set_seed


@hydra.main(version_base="1.3", config_path="../../configs", config_name="train")
def main(cfg: DictConfig) -> float | None:
    """Train a model.

    Args:
        cfg: Hydra config composed from configs/train.yaml + overrides.

    Returns:
        Best validation metric (for HP search), or None.
    """
    set_seed(cfg.seed, deterministic=cfg.get("deterministic", True))

    # --- Fabric ---
    loggers = []
    if "logger" in cfg:
        for _, lg_cfg in cfg.logger.items():
            loggers.append(hydra.utils.instantiate(lg_cfg))

    fabric = L.Fabric(
        accelerator=cfg.trainer.accelerator,
        devices=cfg.trainer.devices,
        precision=cfg.trainer.precision,
        loggers=loggers or None,
    )
    fabric.launch()

    # --- Data ---
    loaders = create_dataloaders(
        n_samples=cfg.data.n_samples,
        n_features=cfg.data.n_features,
        n_classes=cfg.data.n_classes,
        batch_size=cfg.data.batch_size,
        num_workers=cfg.data.num_workers,
        val_split=cfg.data.val_split,
        seed=cfg.seed,
    )

    # --- Model + Optimizer ---
    model = ExampleModel(
        n_features=cfg.model.n_features,
        hidden_dim=cfg.model.hidden_dim,
        n_classes=cfg.model.n_classes,
    )
    optimizer = torch.optim.Adam(
        model.parameters(), lr=cfg.model.lr, weight_decay=cfg.model.weight_decay
    )

    # Fabric wraps model, optimizer, dataloaders
    model, optimizer = fabric.setup(model, optimizer)
    train_loader: DataLoader = fabric.setup_dataloaders(loaders.train)  # type: ignore[assignment]
    val_loader: DataLoader = fabric.setup_dataloaders(loaders.val)  # type: ignore[assignment]

    # --- Objective (pluggable: supervised / contrastive / masked / next-state) ---
    objective = hydra.utils.instantiate(cfg.loss)

    # --- LR scheduler (per-step; trainer.scheduler.name=none keeps constant LR) ---
    accumulate = cfg.trainer.get("accumulate_grad_batches", 1)
    steps_per_epoch = math.ceil(len(train_loader) / accumulate)
    scheduler = build_scheduler(
        optimizer,
        name=cfg.trainer.scheduler.name,
        total_steps=cfg.trainer.max_epochs * steps_per_epoch,
        warmup_steps=cfg.trainer.scheduler.warmup_steps,
        min_lr_ratio=cfg.trainer.scheduler.min_lr_ratio,
    )

    output_dir = Path(hydra.core.hydra_config.HydraConfig.get().runtime.output_dir)  # type: ignore[attr-defined]

    # --- Resume ---
    # Everything needed to continue a run lives in last.ckpt. `fabric.load`
    # restores modules/optimizers in place and overwrites the scalar entries.
    state: dict = {
        "model": model,
        "optimizer": optimizer,
        "epoch": -1,
        "best_val_loss": float("inf"),
        "best_val_acc": 0.0,
        "patience_counter": 0,
    }
    if scheduler is not None:
        state["scheduler"] = scheduler

    resume = cfg.trainer.get("resume")
    resume_path: Path | None = None
    if resume == "auto":
        candidate = output_dir / "last.ckpt"
        resume_path = candidate if candidate.exists() else None
    elif resume:
        resume_path = Path(resume)
    if resume_path is not None:
        fabric.load(resume_path, state)
        fabric.print(f"Resumed from {resume_path} (epoch {state['epoch']})")

    start_epoch = int(state["epoch"]) + 1
    best_val_loss = float(state["best_val_loss"])
    best_val_acc = float(state["best_val_acc"])
    patience_counter = int(state["patience_counter"])

    fabric.print(f"Config:\n{OmegaConf.to_yaml(cfg)}")
    fabric.print(f"Output dir: {output_dir}")
    fabric.print(f"Parameters: {sum(p.numel() for p in model.parameters()):,}")

    for epoch in range(start_epoch, cfg.trainer.max_epochs):
        train_loss = train_epoch(
            fabric,
            model,
            optimizer,
            objective,
            train_loader,
            epoch,
            scheduler=scheduler,
            accumulate_grad_batches=accumulate,
            gradient_clip_val=cfg.trainer.get("gradient_clip_val", 1.0),
        )
        val_loss, val_acc = validate(fabric, model, objective, val_loader, epoch)

        fabric.print(
            f"Epoch {epoch:3d} | train_loss={train_loss:.4f} | "
            f"val_loss={val_loss:.4f} | val_acc={val_acc:.4f}"
        )

        # Checkpointing
        if val_loss < best_val_loss:
            best_val_loss = val_loss
            best_val_acc = val_acc
            patience_counter = 0
        else:
            patience_counter += 1

        state.update(
            epoch=epoch,
            best_val_loss=best_val_loss,
            best_val_acc=best_val_acc,
            patience_counter=patience_counter,
        )
        if patience_counter == 0:
            fabric.save(output_dir / "best.ckpt", state)
        fabric.save(output_dir / "last.ckpt", state)

        # Early stopping
        if patience_counter >= cfg.trainer.patience:
            fabric.print(f"Early stopping at epoch {epoch} (patience={cfg.trainer.patience})")
            break

    # Save final metrics for multi-seed aggregation
    metrics = {"val/loss": best_val_loss, "val/acc": best_val_acc}
    with open(output_dir / "metrics.json", "w") as f:
        json.dump(metrics, f, indent=2)

    # Flush loggers (CSVLogger buffers writes; trackers close their runs here).
    for logger in fabric.loggers:
        logger.finalize("success")

    fabric.print(f"Best val_loss={best_val_loss:.4f} | val_acc={best_val_acc:.4f}")
    return best_val_acc


if __name__ == "__main__":
    main()
