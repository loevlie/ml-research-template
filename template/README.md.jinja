## Installation

```bash
# Install uv (if you don't have it)
curl -LsSf https://astral.sh/uv/install.sh | sh

# Install this project
uv sync --extra dev
uv run pre-commit install

# Optional: extra tracking backends
uv sync --extra tracking-wandb   # W&B (cloud)
uv sync --extra tracking-aim     # Aim (local, rich UI)

# Optional: publication-ready statistics
uv sync --extra stats            # pingouin

# Optional: SLURM submission (HPC clusters)
uv sync --extra cluster          # hydra-submitit-launcher
```

## Quick Start

```bash
# Train with defaults
uv run python src/{{ package_name }}/train.py

# Train with CLI overrides
uv run python src/{{ package_name }}/train.py model.lr=1e-3 data.batch_size=128

{% if include_example -%}
# Run a named experiment config
uv run python src/{{ package_name }}/train.py experiment=example

# Multi-seed run (5 seeds)
bash scripts/run_seeds.sh experiment=example seeds="42,123,456,789,1337"

# Aggregate and get significance tests
python scripts/aggregate_seeds.py outputs/multi_seed_YYYYMMDD_HHMMSS

{% endif -%}
# Evaluate a checkpoint
uv run python src/{{ package_name }}/eval.py ckpt_path=/path/to/checkpoint.ckpt

# HP search with Optuna
uv run python src/{{ package_name }}/train.py -m hparams_search=optuna

# Switch logger via config ({{ logger }} is default)
uv run python src/{{ package_name }}/train.py logger=wandb          # cloud — needs: uv sync --extra tracking-wandb
uv run python src/{{ package_name }}/train.py logger=aim             # local — needs: uv sync --extra tracking-aim
uv run python src/{{ package_name }}/train.py logger=tensorboard     # local
uv run python src/{{ package_name }}/train.py logger=csv             # local, zero dependencies
```

