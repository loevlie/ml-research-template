[build-system]
requires = ["setuptools>=68.0", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ package_name|replace('_', '-') }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "README.md"
license = "MIT"
requires-python = ">={{ python_version }}"
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" },
]
dependencies = [
{%- if framework == 'pytorch' %}
    # Core
    "torch>=2.2.0",
    "lightning>=2.5.0",
{%- else %}
    # Core (jax[cuda12] below routes GPU wheels on Linux)
    "jax>=0.5.0",
{%- if cuda_version != 'cpu' %}
    "jax[cuda12]>=0.5.0; sys_platform == 'linux'",
{%- endif %}
    "flax>=0.11.0",
    "optax>=0.2.4",
{%- endif %}
    # Config (typed: pydantic schemas + tyro CLI; utils/cli.py keeps Hydra's syntax)
    "tyro>=1.0.0",
    "pydantic>=2.7.0",
    "pyyaml>=6.0.0",
    # HP search (scripts/tune.py)
    "optuna>=4.0.0",
    # Tracking (tensorboard is included with torch)
    # Shape checking & types
    "jaxtyping>=0.2.28",
    "beartype>=0.17.0",
    # Data & stats
    "numpy>=1.26.0",
    "scipy>=1.12.0",
    "pandas>=2.2.0",
    # Visualization
    "matplotlib>=3.8.0",
    "seaborn>=0.13.0",
    # Utilities
    "rich>=13.7.0",
    "tqdm>=4.66.0",
{%- if flavor == "tabular" %}
    # Tabular: OpenML tasks + sklearn estimator interface
    "scikit-learn>=1.4.0",
    "openml>=0.14.0",
    # Benchmark-cell caching (code-aware via utils/codever.py)
    "exca>=0.5.26",
{%- elif flavor == "multimodal" %}
    # Multimodal: backbones + data
    "timm>=1.0.0",
    "open_clip_torch>=2.24.0",
    "transformers>=4.44.0",
    "datasets>=2.20.0",
{%- endif %}
{%- if logger == "tensorboard" %}
    # Default logger
    "tensorboard>=2.15.0",
{%- if framework == 'jax' %}
    "tensorboardX>=2.6",
{%- endif %}
{%- elif logger == "wandb" %}
    # Default logger
    "wandb>=0.16.0",
{%- elif logger == "trackio" %}
    # Default logger (pre-1.0: breaking changes allowed, so cap below 1)
    "trackio>=0.10.0,<1",
{%- endif %}
]

[project.optional-dependencies]
dev = [
    "ruff>=0.4.0",
    "mypy>=1.9.0",
    "pre-commit>=3.7.0",
    "pytest>=8.1.0",
    "pytest-cov>=5.0.0",
    "ipykernel>=6.29.0",
{%- if framework == 'pytorch' %}
    # Debugging quality-of-life
    "lovely-tensors>=0.1.18",   # readable tensor reprs: shape, stats, NaN flags
    "torchinfo>=1.8.0",         # model summaries with output shapes + param counts
    "hypothesis-torch>=2.0.0",  # property-based tests over tensors/modules
{%- endif %}
]
{%- if include_example %}
docs = [
    "mkdocs>=1.5.0",
    "mkdocs-material>=9.5.0",
    "mkdocstrings[python]>=0.24.0",
]
demo = [
    "gradio>=6,<7",
]
{%- endif %}
tracking-wandb = [
    "wandb>=0.16.0",
]
tracking-trackio = [
    "trackio>=0.10.0,<1",
]
stats = [
    "pingouin>=0.5.4",
]
{%- if flavor == "tabular" %}
tabular-baselines = [
    # Foundation-model baselines for the benchmark harness.
    # NOTE: TabPFN weights are licensed for non-commercial research use;
    # TabICL is fully open (weights + pretraining code).
    "tabpfn>=2.0.0",
    "tabicl>=0.1.0",
]
{%- endif %}
cluster = [
    # SLURM submission for scripts/sweep.py and scripts/tune.py
    "submitit>=1.5.2",
]

[tool.setuptools.packages.find]
where = ["src"]

{%- if framework == 'pytorch' %}
# --- uv: PyTorch CUDA/CPU handling ---
# Docs: https://docs.astral.sh/uv/guides/integration/pytorch/
{%- if cuda_version == "cpu" %}
[tool.uv.sources]
torch = [
    { index = "pytorch-cpu", marker = "sys_platform == 'linux'" },
]
torchvision = [
    { index = "pytorch-cpu", marker = "sys_platform == 'linux'" },
]

[[tool.uv.index]]
name = "pytorch-cpu"
url = "https://download.pytorch.org/whl/cpu"
explicit = true
{%- else %}
[tool.uv.sources]
torch = [
    { index = "pytorch-{{ cuda_version }}", marker = "sys_platform == 'linux'" },
]
torchvision = [
    { index = "pytorch-{{ cuda_version }}", marker = "sys_platform == 'linux'" },
]

[[tool.uv.index]]
name = "pytorch-{{ cuda_version }}"
url = "https://download.pytorch.org/whl/{{ cuda_version }}"
explicit = true
{%- endif %}
{%- endif %}

# --- Ruff (replaces black + isort + flake8) ---
[tool.ruff]
line-length = 100
target-version = "py{{ python_version|replace('.', '') }}"

[tool.ruff.lint]
select = [
    "E",    # pycodestyle errors
    "W",    # pycodestyle warnings
    "F",    # pyflakes
    "I",    # isort
    "UP",   # pyupgrade
    "B",    # flake8-bugbear
    "SIM",  # flake8-simplify
    "RUF",  # ruff-specific
]
ignore = [
    "E501",  # line length (handled by formatter)
    "F722",  # jaxtyping shape annotations use string syntax ruff doesn't understand
]

[tool.ruff.lint.per-file-ignores]
# cli.py ships with the template and must stay valid on Python 3.11 —
# PEP 695 type-parameter syntax (UP047) would break those projects.
"src/{{ package_name }}/utils/cli.py" = ["UP047"]

[tool.ruff.lint.isort]
known-first-party = ["{{ package_name }}"]

# --- Mypy ---
[tool.mypy]
python_version = "{{ python_version }}"
warn_return_any = true
warn_unused_configs = true
ignore_missing_imports = true  # relaxed mode to start

# --- Pytest ---
[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "-v --tb=short"
