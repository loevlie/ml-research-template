site_name: {{ project_name }}
site_description: {{ project_description }}
repo_url: https://github.com/{{ author_name|lower|replace(' ', '-') }}/{{ package_name|replace('_', '-') }}

theme:
  name: material
  palette:
    primary: indigo
  features:
    - navigation.tabs
    - navigation.sections
    - search.highlight

plugins:
  - search
  - mkdocstrings:
      handlers:
        python:
          options:
            docstring_style: google
            show_source: true
            show_root_heading: true

nav:
  - Home: index.md
  - API Reference:
    - Models: api/models.md
    - Data: api/data.md
    - Utils: api/utils.md

markdown_extensions:
  - pymdownx.highlight
  - pymdownx.superfences
  - admonition
  - tables
