# @package _global_
#
# Hydra SLURM launcher via submitit.
# Requires: uv sync --extra cluster
#
# Usage:
#   # Single run on SLURM
#   python src/{{ package_name }}/train.py -m launcher=slurm
#
#   # Fan out a sweep (5 seeds in parallel jobs)
#   python src/{{ package_name }}/train.py -m launcher=slurm seed=42,43,44,45,46
#
#   # Compose with the Optuna sweeper
#   python src/{{ package_name }}/train.py -m hparams_search=optuna launcher=slurm
#
# Fill in `partition` and `account` for your cluster (see configs/local/default.yaml
# if you want to keep them machine-specific and gitignored).

defaults:
  - override /hydra/launcher: submitit_slurm

hydra:
  launcher:
    timeout_min: 1440         # 24h; override per-experiment if needed
    nodes: 1
    tasks_per_node: 1
    gpus_per_node: 1
    cpus_per_task: 8
    mem_gb: 64
    partition: ???            # fill in: e.g. 'gpu', 'a100'
    account: ???              # fill in: your SLURM account
    # qos: normal
    # constraint: a100
    # gres: gpu:1             # some clusters prefer this over gpus_per_node
    additional_parameters:
      requeue: ""
      signal: "USR1@90"       # SIGUSR1 90s before walltime → Lightning auto-requeue
    setup:
      - "source .venv/bin/activate"
