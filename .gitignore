data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Model checkpoints
*.ckpt
*.pt
*.pth
*.bin

# Local machine-specific configs
configs/local/default.yaml

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Type checking & linting caches
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Docker
.dockerignore

# Secrets
.env
*.key
